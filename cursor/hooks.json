{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "node hooks/session-rehydrate.js",
        "timeout": 5
      },
      {
        "command": "node hooks/post-compact-rehydrate.js",
        "matcher": "compact",
        "timeout": 8
      }
    ],
    "preCompact": [
      {
        "command": "node hooks/pre-compact-flush.js",
        "timeout": 8
      }
    ],
    "preToolUse": [
      {
        "command": "node hooks/secret-guard.js",
        "matcher": "Write|StrReplace",
        "timeout": 5,
        "failClosed": true
      }
    ],
    "postToolUse": [
      {
        "command": "node hooks/session-checkpoint-update.js",
        "matcher": "Write|StrReplace",
        "timeout": 5
      }
    ]
  }
}
